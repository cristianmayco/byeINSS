# =============================================================================
# byeINSS — .gitignore
# =============================================================================

# Dependências (instaladas via npm install)
node_modules/

# Build output (electron-builder gera instaladores aqui)
dist/
out/
release/

# Banco SQLite (dados pessoais — criado em runtime em userData)
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# IDEs e editores
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Claude Code / MCP local (artefatos de desenvolvimento)
.claude/settings.local.json
.playwright-mcp/

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
.Trashes

# Variáveis de ambiente / secrets locais
.env
.env.local
.env.*.local

# Arquivos temporários
tmp/
temp/
*.tmp
*.bak
*.cache

# Coverage / testes
coverage/
.nyc_output/

# TypeScript / build artifacts (caso adicione no futuro)
*.tsbuildinfo
